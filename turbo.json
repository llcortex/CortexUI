{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**",
        "app/**",
        "components/**",
        "package.json",
        "tsconfig.json",
        "next.config.mjs",
        "next-env.d.ts"
      ],
      "outputs": ["dist/**", ".next/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"],
      "inputs": [
        "src/**",
        "app/**",
        "components/**",
        "package.json",
        "tsconfig.json",
        "eslint.config.mjs",
        "next.config.mjs",
        "next-env.d.ts"
      ],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**",
        "app/**",
        "components/**",
        "tests/**",
        "package.json",
        "tsconfig.json",
        "next.config.mjs",
        "next-env.d.ts"
      ],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "inputs": [
        "src/**",
        "app/**",
        "components/**",
        "package.json",
        "tsconfig.json",
        "next.config.mjs",
        "next-env.d.ts"
      ],
      "outputs": []
    }
  }
}
